{
  "name": "glrs",
  "private": true,
  "description": "Unified glrs ecosystem: harness-opencode + agentic + assume + cli + docs. Published under @glrs-dev on npm.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iceglober/glrs.git"
  },
  "homepage": "https://glrs.dev",
  "packageManager": "bun@1.2.0",
  "workspaces": [
    "packages/*",
    "packages/assume/npm/*",
    "docs",
    "infra/gcp",
    "tests/*"
  ],
  "scripts": {
    "build": "bun run --filter=@glrs-dev/cli --filter=@glrs-dev/assume --filter=@glrs-dev/docs --filter=@glrs-dev/infra-gcp build",
    "test": "bun test",
    "typecheck": "bun run --filter='*' typecheck",
    "lint": "bun run --filter='*' lint",
    "changeset": "changeset",
    "version-packages": "changeset version && bun run --cwd packages/assume sync:version && bun install",
    "release": "bun run build && changeset publish",
    "dev": "bun run --filter=@glrs-dev/harness-plugin-opencode dev",
    "dev:nobuild": "bun run --filter=@glrs-dev/harness-plugin-opencode dev:nobuild"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "typescript": "^5.7.3"
  }
}
