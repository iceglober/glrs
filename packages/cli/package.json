{
  "name": "@glrs-dev/cli",
  "version": "2.26.2",
  "description": "Unified CLI for the @glrs-dev ecosystem — OpenCode agent harness dispatch + worktree management.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iceglober/glrs.git",
    "directory": "packages/cli"
  },
  "homepage": "https://glrs.dev",
  "bugs": {
    "url": "https://github.com/iceglober/glrs/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "glrs": "./dist/cli.js"
  },
  "files": [
    "dist",
    "dist/node_modules",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "glrs",
    "cli",
    "dispatcher",
    "opencode",
    "worktree"
  ],
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test src/ test/",
    "lint": "echo 'no linter configured yet'",
    "prepare-publish": "bun scripts/prepare-publish.ts",
    "restore-publish": "bun scripts/restore-publish.ts",
    "verify-publishable": "bun scripts/verify-publishable.ts",
    "test:publish-shape": "bun test test/publish-shape.test.ts test/pack-install-smoke.test.ts"
  },
  "dependencies": {
    "@glrs-dev/autopilot": "workspace:*",
    "@glrs-dev/adapter-claude-code": "workspace:*",
    "@glrs-dev/adapter-opencode": "workspace:*",
    "@glrs-dev/harness-plugin-opencode": "workspace:*",
    "@inkjs/ui": "^2.0.0",
    "@inquirer/prompts": "^8.4.2",
    "@opencode-ai/plugin": "^1.15",
    "@opencode-ai/sdk": "^1.15",
    "cmd-ts": "^0.15.0",
    "ink": "^5.0.0",
    "picomatch": "^4.0.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^18.3.1",
    "ulid": "^3.0.2",
    "yaml": "^2.8.3",
    "zod": "4.1.8"
  },
  "devDependencies": {
    "@glrs-dev/autopilot": "workspace:*",
    "@glrs-dev/adapter-opencode": "workspace:*",
    "@types/bun": "latest",
    "@types/node": "^22",
    "@types/react": "^18.3.0",
    "tsup": "^8",
    "typescript": "^5"
  }
}
