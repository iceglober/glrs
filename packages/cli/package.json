{
  "name": "@glrs-dev/cli",
  "version": "1.2.0",
  "description": "Unified CLI for the @glrs-dev ecosystem — OpenCode agent harness dispatch + worktree management.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iceglober/glrs.git",
    "directory": "packages/cli"
  },
  "homepage": "https://glrs.dev",
  "bugs": {
    "url": "https://github.com/iceglober/glrs/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "glrs": "./dist/cli.js"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "glrs",
    "cli",
    "dispatcher",
    "opencode",
    "worktree"
  ],
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test src/",
    "lint": "echo 'no linter configured yet'"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "@opencode-ai/plugin": "^1.14",
    "@opencode-ai/sdk": "^1.14",
    "cmd-ts": "^0.15.0",
    "picomatch": "^4.0.4",
    "ulid": "^3.0.2",
    "yaml": "^2.8.3",
    "zod": "4.1.8"
  },
  "devDependencies": {
    "@glrs-dev/harness-plugin-opencode": "workspace:*",
    "@types/bun": "latest",
    "@types/node": "^22",
    "tsup": "^8",
    "typescript": "^5"
  }
}
